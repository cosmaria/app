{
  "name": "cosmaria",
  "version": "0.0.1",
  "private": true,
  "description": "COSMARIA — plataforma de cultivo (Grow) e acompanhamento terapêutico (Med). Monorepo Nx. Ver docs/.",
  "workspaces": [
    "apps/*",
    "libs/**"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "jest",
    "typecheck": "nx run-many -t typecheck",
    "api:serve": "nx serve api",
    "api:build": "nx build api",
    "mobile:start": "nx start mobile",
    "graph": "nx graph",
    "db:migrate": "node tools/db/migrate.mjs up",
    "db:migrate:down": "node tools/db/migrate.mjs down",
    "db:seed": "node tools/db/seed.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "node-pg-migrate": {
      "glob": "^11.1.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@nx/js": "^23.0.1",
    "@nx/workspace": "^23.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.8",
    "node-pg-migrate": "^7.9.1",
    "nx": "^23.0.1",
    "prettier": "^3.9.4",
    "react-test-renderer": "19.2.7",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.63.0"
  }
}
