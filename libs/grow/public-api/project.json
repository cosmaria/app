{
  "name": "grow-public-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/grow/public-api/src",
  "projectType": "library",
  "tags": ["scope:grow", "type:public-api"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "cwd": "libs/grow/public-api", "command": "tsc --noEmit -p tsconfig.json" }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "options": { "cwd": "libs/grow/public-api", "command": "tsc -p tsconfig.lib.json" }
    }
  }
}
