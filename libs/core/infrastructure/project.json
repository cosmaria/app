{
  "name": "core-infrastructure",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/infrastructure/src",
  "projectType": "library",
  "tags": ["scope:core", "type:infrastructure"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "cwd": "libs/core/infrastructure", "command": "tsc --noEmit -p tsconfig.json" }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "options": { "cwd": "libs/core/infrastructure", "command": "tsc -p tsconfig.lib.json" }
    }
  }
}
