{
  "name": "shared-contracts",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/contracts/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:shared"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "cwd": "libs/shared/contracts", "command": "tsc --noEmit -p tsconfig.json" }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "options": { "cwd": "libs/shared/contracts", "command": "tsc -p tsconfig.lib.json" }
    }
  }
}
