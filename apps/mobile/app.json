{
  "expo": {
    "name": "COSMARIA",
    "slug": "cosmaria",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.cosmaria.mobile"
    },
    "android": {
      "package": "app.cosmaria.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F14"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0F14"
        }
      ]
    ]
  }
}
