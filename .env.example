# Exemplo de variáveis de ambiente (doc 15 §8).
# Copie para .env (que NUNCA é commitado — ver .gitignore) e preencha.
# Credenciais reais de GCP/Anthropic seguem o padrão porta/adaptador (doc 13 §16.1),
# injetadas somente na camada de Infraestrutura.

# --- API ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL (docker-compose local; em prod = Cloud SQL) ---
DATABASE_URL=postgresql://cosmaria:cosmaria_dev@localhost:5432/cosmaria

# --- Redis (docker-compose local; em prod = Memorystore) ---
REDIS_URL=redis://localhost:6379

# --- Feature flags (porta FeatureFlags, doc 13 §16.1) ---
# Vínculo público entre Perfis Públicos é Versão 2 (doc 06, decisão consolidada #1):
# modelo de dados pronto desde o MVP, funcionalidade desligada. Ligar aqui não exige
# migration nem mudança de contrato.
FEATURE_VINCULO_DE_PERFIS=false

# --- Pagamento (doc 09 §7, arquétipo API-7) ---
# Segredo compartilhado com o gateway, usado para verificar o HMAC do webhook.
# Sem valor, o webhook rejeita TODO payload (falha fechada). O gateway concreto
# ainda é decisão de negócio (doc 13 §16.1) — a porta ProcessadorDePagamento não muda.
PAGAMENTO_WEBHOOK_SECRET=

# --- Provedores externos (só usados pela camada Infrastructure) ---
# ANTHROPIC_API_KEY=
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=
